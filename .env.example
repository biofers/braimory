# Required: Database password
BRAIMORY_DB_PASSWORD=change-me-to-a-strong-password

# Required: API key for MCP access (64 hex chars recommended)
# Generate with: openssl rand -hex 32
MCP_ACCESS_KEY=change-me-generate-with-openssl-rand-hex-32

# Optional: Encryption at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
# If set, all thought content is encrypted in the database.
# If not set, thoughts are stored in plaintext.
ENCRYPTION_KEY=

# Optional: OAuth credentials for Claude Desktop / browser-based clients
# If not set, OAuth login is disabled (API key auth still works).
OAUTH_USERNAME=
OAUTH_PASSWORD=

# Optional: Ollama configuration
# OLLAMA_URL=http://host.docker.internal:11434
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
# LLM_MODEL=llama3.2

# Optional: Server configuration
# MCP_HTTP_PORT=3100
# DB_PORT=5433
# DB_POOL_SIZE=10

# Optional: Trust reverse proxy headers for IP detection (rate limiting)
# Set to true ONLY if behind a reverse proxy like Nginx Proxy Manager.
# This does NOT bypass authentication — it only affects which IP is used for rate limiting.
# TRUST_PROXY=false

# Optional: OAuth issuer URL (your public-facing URL for OAuth metadata)
# OAUTH_ISSUER_URL=https://brain.example.com
